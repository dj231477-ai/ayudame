# =============================================================================
# FlowDay — Variables de entorno canónicas (SPEC §C-24, fuente ÚNICA)
# INV-4: Solo las NEXT_PUBLIC_* llegan al browser. Los secretos JAMÁS en cliente.
# Copia este archivo a .env.local (no se versiona). CI verifica aislamiento (§C-18.5).
# =============================================================================

# --- C-24.1 Compartidas (todas las apps) ------------------------------------

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # SOLO backend (INV-4). Nunca NEXT_PUBLIC_*.

# IA en la nube (free tier)
GOOGLE_GEMINI_API_KEY=
GROQ_API_KEY=
CEREBRAS_API_KEY=
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=                  # opcional: fallback de visión (§C-10.3)

# Web Push (VAPID)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:ops@flowday.app

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Email transaccional (decisión D-3: Resend). Si falta, Mailer degrada a no-op + log.
RESEND_API_KEY=
EMAIL_FROM=FlowDay <ops@flowday.app>

# Orquestación
N8N_WEBHOOK_SECRET=                 # HMAC para verificar eventos de n8n (INV-5)
INTERNAL_ADMIN_SECRET=              # para /internal/* (monetization, cleanup)

# Rate limiting (decisión D-1: Upstash Redis, §C-11.1). Si faltan, degrada a "permitir" en dev.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- C-24.2 Específicas de FlowDay (apps/flowday) ---------------------------

NEXT_PUBLIC_APP_URL=https://flowday.app
GOOGLE_CLIENT_ID=                   # OAuth Google Tasks/Calendar
GOOGLE_CLIENT_SECRET=
TOKEN_ENCRYPTION_KEY=               # clave para cifrar refresh tokens de Google (AES-256-GCM). SOLO backend.
OLLAMA_BASE_URL=https://ollama-internal.flowday.app  # hostname privado VM Oracle (NO localhost desde Vercel)
FOUNDER_USER_ID=                    # UUID del fundador en auth.users; activa Ollama qwen3:8b para texto
STRIPE_PRICE_ID_STARTER=
STRIPE_PRICE_ID_GROWTH=
STRIPE_PRICE_ID_POWER=
STRIPE_PRICE_ID_PRO_MONTHLY=
STRIPE_PRICE_ID_PRO_YEARLY=
STRIPE_PRICE_ID_TEAM=

# --- C-24.3 Solo en la VM Oracle (NO en Vercel) -----------------------------
# DOMAIN=n8n.flowday.app
# POSTGRES_PASSWORD=
# N8N_USER=
# N8N_PASSWORD=
# Dentro de la VM, los servicios usan http://localhost:11434 para Ollama.
