{
  "name": "verify-queue",
  "_comment": "SPEC §C-14.3: drena verification_queue. Cuando la visión (Gemini) estuvo agotada, las fotos se encolan; este cron reintenta su verificación cuando vuelve la cuota. n8n no contiene lógica de negocio (AR-3): solo dispara el job 'verify_queue' del scheduler de la app.",
  "nodes": [
    {
      "parameters": {
        "rule": { "interval": [{ "field": "minutes", "minutesInterval": 10 }] }
      },
      "id": "cron-10min",
      "name": "Every 10 minutes",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.1,
      "position": [260, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://ayudame-flowday.vercel.app/internal/scheduler/run",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{\"job\":\"verify_queue\"}",
        "options": {}
      },
      "id": "call-scheduler",
      "name": "POST /internal/scheduler/run",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [520, 300],
      "credentials": {
        "httpHeaderAuth": { "id": "FLOWDAYADMIN0001", "name": "FlowDay Internal Admin" }
      }
    }
  ],
  "connections": {
    "Every 10 minutes": { "main": [[{ "node": "POST /internal/scheduler/run", "type": "main", "index": 0 }]] }
  },
  "settings": { "executionOrder": "v1" }
}
