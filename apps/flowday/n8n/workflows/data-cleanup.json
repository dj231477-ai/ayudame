{
  "name": "data-cleanup",
  "_comment": "SPEC §C-12.2 / §C-15.3: cron 03:00 UTC; borrado por lotes paginado e idempotente. La app realiza el barrido (AR-3).",
  "nodes": [
    {
      "parameters": {
        "rule": { "interval": [{ "field": "days", "daysInterval": 1, "triggerAtHour": 3 }] }
      },
      "id": "cron-daily-3am",
      "name": "Daily 03:00 UTC",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.1,
      "position": [260, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://ayudame-flowday.vercel.app/internal/cleanup/run",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "options": { "timeout": 290000 }
      },
      "id": "call-cleanup",
      "name": "POST /internal/cleanup/run",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [520, 300],
      "credentials": {
        "httpHeaderAuth": { "id": "FLOWDAYADMIN0001", "name": "FlowDay Internal Admin" }
      }
    }
  ],
  "connections": {
    "Daily 03:00 UTC": { "main": [[{ "node": "POST /internal/cleanup/run", "type": "main", "index": 0 }]] }
  },
  "settings": { "executionOrder": "v1" }
}
