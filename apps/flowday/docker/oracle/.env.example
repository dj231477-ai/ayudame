# Variables SOLO de la VM Oracle (no en Vercel). SPEC §C-24.3.
DOMAIN=n8n.flowday.app
POSTGRES_PASSWORD=
N8N_USER=
N8N_PASSWORD=

# Para que los workflows llamen a la app de producción de forma firmada:
APP_URL=https://flowday.app
INTERNAL_ADMIN_SECRET=          # debe coincidir con el de la app (Vercel)
N8N_WEBHOOK_SECRET=             # HMAC; debe coincidir con el de la app (Vercel)
