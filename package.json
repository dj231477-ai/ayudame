{
  "name": "flowday-platform",
  "version": "2.0.0",
  "private": true,
  "description": "FlowDay — PWA de accountability por foto verificada con IA. Monorepo (SPEC §C-5).",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\"",
    "dev:flowday": "turbo run dev --filter=flowday",
    "ci:no-secrets": "node scripts/check-no-secrets.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "turbo": "2.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "comment:overrides": "Pin supabase-js a 2.49.x: la 2.108 reordenó los genéricos de SupabaseClient e incompatibiliza con @supabase/ssr 0.5.2 (SPEC §C-6 fija elecciones, no parches).",
  "overrides": {
    "@supabase/supabase-js": ">=2.49.0 <2.50.0"
  },
  "packageManager": "npm@10.9.0"
}
